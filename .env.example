# ── VEY1 environment ─────────────────────────────────────
# Copy to .env, fill in real values, never commit

# Server
NODE_ENV=production
PORT=8080
HOST=0.0.0.0
DATA_DIR=./data
OUTPUT_DIR=./data/outputs
PUBLIC_BASE_URL=https://vey1.xyz

# LLM (FreeModel.dev is the default; swap to OpenAI by changing these)
OPENAI_API_KEY=fe_oa_replace_me
OPENAI_BASE_URL=https://api.freemodel.dev/v1
OPENAI_MODEL=gpt-4o-mini

# X402 payment (USDT0 on X Layer mainnet)
X402_NETWORK=eip155:196
X402_ASSET=0x779ded0c9e1022225f8e0630b35a9b54be713736
X402_RECEIVING_WALLET=0xREPLACE_ME
X402_AUDIT_PRICE=1.5

# OnchainOS (OKX) — uses CLI on deploy host; no keys needed in app
# `onchainos agent activate` runs the listing

# Puppeteer
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_SKIP_DOWNLOAD=true
